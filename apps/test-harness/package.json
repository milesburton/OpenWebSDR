{
  "name": "@next-sdr/test-harness",
  "version": "0.1.0",
  "description": "Integration test harness for the Next SDR platform",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@next-sdr/contracts": "workspace:*",
    "@next-sdr/test-utils": "workspace:*",
    "@next-sdr/scenario-definitions": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
