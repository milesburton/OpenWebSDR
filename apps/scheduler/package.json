{
  "name": "@next-sdr/scheduler",
  "version": "0.1.0",
  "description": "Scheduler service — validates tune requests and manages channel allocation",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:unit": "vitest run --reporter=verbose",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@next-sdr/contracts": "workspace:*",
    "@next-sdr/config": "workspace:*",
    "fastify": "^4.28.0",
    "pino": "^9.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@next-sdr/test-utils": "workspace:*"
  }
}
